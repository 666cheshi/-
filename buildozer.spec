[app]

title = DecryptTool

package.name = decrypttool

package.domain = org.example

source.dir = .

source.include_exts = py,png,jpg,jpeg,gif,kv,atlas,ttf,json

version = 1.0

requirements = python3,kivy

orientation = portrait

fullscreen = 0

log_level = 2

android.api = 31

android.minapi = 21

android.sdk = 31

android.ndk = 25b

android.archs = arm64-v8a, armeabi-v7a

android.permissions = INTERNET

presplash.filename =

icon.filename =

[buildozer]

log_level = 2

warn_on_root = 1
